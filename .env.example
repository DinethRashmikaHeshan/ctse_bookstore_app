# Shared secrets - use the same values across all services
JWT_SECRET=bookstore-super-secret-key-change-in-prod
INTERNAL_API_KEY=internal-service-key-change-in-prod

# MongoDB Cloud configuration
MONGODB_URI_USER=mongodb+srv://<username>:<password>@cluster0.mongodb.net/bookstore_users?retryWrites=true&w=majority
MONGODB_URI_BOOK=mongodb+srv://<username>:<password>@cluster0.mongodb.net/bookstore_books?retryWrites=true&w=majority
MONGODB_URI_ORDER=mongodb+srv://<username>:<password>@cluster0.mongodb.net/bookstore_orders?retryWrites=true&w=majority
MONGODB_URI_NOTIF=mongodb+srv://<username>:<password>@cluster0.mongodb.net/bookstore_notifications?retryWrites=true&w=majority
